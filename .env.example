# Database (PostgreSQL)
DATABASE_URL="postgresql://smartcabinet:SmartCabinet2024!@localhost:5432/smart_cabinet?schema=public&connection_limit=20"

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Website Base URL (for sitemap, SEO, etc.)
NEXT_PUBLIC_BASE_URL=https://www.wstoolcabinet.com

# JWT Secret
JWT_SECRET=smart-cabinet-jwt-secret-2024-change-in-production
NEXT_PUBLIC_JWT_SECRET=smart-cabinet-jwt-secret-2024-change-in-production

# ===== V8: 后台管理 JWT（独立于用户 JWT，避免越权串号）=====
ADMIN_JWT_SECRET=change-me-admin-secret-v8

# ===== V8: 支付（Stripe / PayPal 真实 SDK；微信/支付宝留空即 mock）=====
# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox   # sandbox|live
# 微信支付（真实接入时填，留空即 mock）
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_ENABLED=false
# 支付宝（真实接入时填，留空即 mock）
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_ENABLED=false

# ===== V8: 服务管理（白名单固定，nginx 模板默认值）=====
SERVICE_NGINX_CONF_PATH=/etc/nginx/conf.d/smart-cabinet.conf
DEFAULT_SITE_DOMAIN=www.wstoolcabinet.com
DEFAULT_SITE_PORT=3000
DEFAULT_SSL_EMAIL=admin@wstoolcabinet.com
