<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400" viewBox="0 0 600 400">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#047857;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#34d399;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="600" height="400" fill="url(#bg)" rx="12"/>
  <rect x="30" y="30" width="540" height="340" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="2" rx="8"/>
  <rect x="180" y="100" width="240" height="170" fill="rgba(255,255,255,0.08)" rx="8"/>
  <ellipse cx="300" cy="175" rx="70" ry="40" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
  <ellipse cx="300" cy="175" rx="45" ry="25" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
  <rect x="270" y="145" width="60" height="8" fill="rgba(255,255,255,0.2)" rx="2"/>
  <rect x="250" y="200" width="100" height="30" fill="rgba(255,255,255,0.1)" rx="4"/>
  <text x="300" y="255" text-anchor="middle" fill="rgba(255,255,255,0.5)" font-family="system-ui,-apple-system,sans-serif" font-size="14">300g × 0.1g</text>
  <text x="300" y="320" text-anchor="middle" fill="white" font-family="system-ui,-apple-system,sans-serif" font-size="22" font-weight="600">SWC-300</text>
  <text x="300" y="345" text-anchor="middle" fill="rgba(255,255,255,0.7)" font-family="system-ui,-apple-system,sans-serif" font-size="13">Smart Weighing Cabinet</text>
