classDiagram
    %% ===== 数据模型（Prisma）=====
    class User {
        +String id
        +String email
        +String role
        +Boolean isActive
        +Json cart
        +Order[] orders
    }
    class Order {
        +String id
        +String userId
        +String status
        +Float total
        +Json shippingAddress
        +String paymentMethod
        +String paymentStatus
        +String transactionId
        +DateTime paidAt
        +OrderItem[] items
        +Payment payment
    }
    class OrderItem {
        +String id
        +String orderId
        +String productId
        +Int quantity
        +Float price
        +Json name
    }
    class Payment {
        +String id
        +String orderId
        +String method
        +String status
        +Float amount
        +String currency
        +String transactionId
        +Json rawPayload
    }

    User "1" --> "0..*" Order : owns
    Order "1" --> "1..*" OrderItem : contains
    Order "1" --> "0..1" Payment : has

    %% ===== 前端购物车 =====
    class CartContext {
        +addItem(product)
        +removeItem(productId)
        +updateQty(productId, n)
        +mergeWithUserCart()
        -state: CartItem[]
    }
    class CartItem {
        +String productId
        +Int quantity
        +Float price
        +Json name
        +String image
    }
    CartContext "1" --> "0..*" CartItem : holds

    %% ===== 支付服务层 =====
    class PaymentProvider {
        <<interface>>
        +createPayment(input) CreatePaymentResult
        +verifyWebhook(raw, sig) WebhookResult
    }
    class StripeProvider
    class PayPalProvider
    class WechatProvider
    class AlipayProvider
    PaymentProvider <|.. StripeProvider
    PaymentProvider <|.. PayPalProvider
    PaymentProvider <|.. WechatProvider
    PaymentProvider <|.. AlipayProvider

    class PaymentConfig {
        +isMock(method) Boolean
        +resolveCurrency(locale) String
    }

    %% ===== API 路由 =====
    class OrdersApi {
        +POST create(order)
    }
    class CartApi {
        +GET getUserCart()
        +POST mergeCart(items)
    }
    class PaymentApi {
        +POST createSession()
        +POST webhook()
    }
    class BlogMergeLib {
        +getMergedBlogList(opts) MergedBlog[]
        +getMergedBlogBySlug(slug) MergedBlog
    }

    %% ===== 后台服务 =====
    class AdminUserService {
        +listUsers()
        +updateStatus()
        +updateRole()
    }
    class AdminOrderService {
        +listOrders(filter)
        +updateStatus(id, status)
    }
    class ServiceManager {
        +execWhitelisted(action, params)
    }
    class CommandWhitelist {
        +validate(action, params) Boolean
    }
    class RunCommand {
        +execFile(cmd, args[])
    }
    ServiceManager --> CommandWhitelist : validates
    ServiceManager --> RunCommand : invokes

    %% ===== 关系标注 =====
    OrdersApi ..> PaymentProvider : uses
    OrdersApi ..> Order : persists
    CartApi ..> User : persists cart
    PaymentApi ..> PaymentProvider : uses
    PaymentApi ..> Payment : updates
    BlogMergeLib ..> Order : (none)
    AdminUserService ..> User : queries
    AdminOrderService ..> Order : queries
